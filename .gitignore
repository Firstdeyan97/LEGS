# ==========================================
# LEGS Project - .gitignore
# ==========================================

# 1. Node Modules (Tidak perlu di-push karena ukurannya besar)
node_modules/
backend/node_modules/

# 2. Environment Variables (SANGAT RAHASIA - Berisi Password DB & JWT)
.env
.env.local
.env.development
.env.test
.env.production

# 3. Log Files (Catatan error dari Winston & NPM)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 4. Database Files (Mencegah database SQLite lokal ikut ter-push jika dipakai)
*.sqlite
*.sqlite3
backend/db/*.sqlite

# 5. OS Generated Files (File sampah bawaan sistem operasi)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 6. IDE & Text Editors (Pengaturan lokal VSCode / JetBrains Anda)
.idea/
.vscode/
*.swp
*.swo